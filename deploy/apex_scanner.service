[Unit]
Description=APEX Scanner Docker Compose
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/path/to/apex_scanner
ExecStart=/usr/bin/docker compose -f /path/to/apex_scanner/docker-compose.prod.yml up -d
ExecStop=/usr/bin/docker compose -f /path/to/apex_scanner/docker-compose.prod.yml down
Restart=always
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
